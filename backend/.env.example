# Server Configuration
PORT=5000
NODE_ENV=development

# Database (append ?connection_limit=25&pool_timeout=30 in production)
DATABASE_URL=postgresql://user:password@localhost:5432/study_compass?connection_limit=25&pool_timeout=30

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d

# Email Service (for password reset, email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# HuggingFace API (for sentiment classification)
HUGGINGFACE_API_KEY=your_huggingface_api_keyz
HUGGINGFACE_MODEL_URL=https://api-inference.huggingface.co/models/nlptown/bert-base-multilingual-uncased-sentiment

# Sentiment Classification Threshold
SENTIMENT_NEGATIVE_CONFIDENCE_THRESHOLD=0.85
